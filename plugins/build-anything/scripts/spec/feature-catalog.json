          "post video",
          "publish video"
        ]
      },
      {
        "name": "video playback",
        "synonyms": [
          "play video",
          "watch video",
          "video player",
          "stream video",
          "<video>",
          "videojs",
          "hls",
          "dash"
        ]
      },
      {
        "name": "video listing",
        "synonyms": [
          "list videos",
          "lists videos",
          "listing videos",
          "video list",
          "video feed",
          "browse videos",
          "video catalog"
        ]
      },
      {
        "name": "user accounts",
        "synonyms": [
          "register",
          "signup",
          "login",
          "authentication",
          "auth",
          "jwt"
        ]
      },
      {
        "name": "comments",
        "synonyms": [
          "comment",
          "reply",
          "thread"
        ]
      },
      {
        "name": "video metadata",
        "synonyms": [
          "title",
          "description",
          "thumbnail",
          "tags"
        ]
      }
    ],
    "stack_fitness": {
      "required_capabilities": [
        "blob_object_store",
        "transcode_worker",
        "cdn",
        "media_streaming_protocol",
        "relational_db_concurrent_writer"
      ],
      "recommended_capabilities": [
        "search_index",
        "cache_layer"
      ],
      "rationale": "User-generated video at any non-trivial scale requires durable object storage, async transcode to adaptive ladders, CDN edge delivery, and a concurrent-writer DB for metadata. A single Express+SQLite+multer/disk stack covers none of these."
    },
    "scale_tiers": {
      "mvp": {
        "required_capabilities": [
          "blob_object_store",
          "transcode_worker",
          "relational_db_concurrent_writer"
        ],
        "recommended_capabilities": [
          "cdn"
        ],
        "disqualified_packages": [
          "multer-disk",
          "express-fileupload",
          "better-sqlite3"
        ],
        "cost_band": {
          "min_usd_month": 0,
          "max_usd_month": 200
        },
        "rationale": "Managed all-in-one (Cloudinary/Mux/Cloudflare-Stream) acceptable at <1K DAU — CDN + transcode + storage bundled. Disk uploads still forbidden: laptop survives, prod node restart does not."
      },
      "growth": {
        "required_capabilities": [
          "blob_object_store",
          "transcode_worker",
          "cdn",
          "media_streaming_protocol",
          "relational_db_concurrent_writer",
          "cache_layer"
        ],
        "recommended_capabilities": [
          "search_index",
          "image_thumbnail_pipeline"
        ],
        "disqualified_packages": [
          "multer-disk",
          "express-fileupload",
          "better-sqlite3"
        ],
        "cost_band": {
          "min_usd_month": 200,
          "max_usd_month": 3000
        },
        "rationale": "Past 1K DAU, separate object store + dedicated CDN + cache for hot videos mandatory. Adaptive bitrate via HLS/DASH required — raw MP4 forecloses bandwidth optimisation at this tier."
      },
      "scale": {
        "required_capabilities": [
          "blob_object_store",
          "transcode_worker",
          "cdn",
          "media_streaming_protocol",
          "relational_db_concurrent_writer",
          "cache_layer",
          "search_index",
          "image_thumbnail_pipeline"
        ],
        "recommended_capabilities": [
          "fanout_queue",
          "notification_pipeline"
        ],
        "disqualified_packages": [
          "multer-disk",
          "express-fileupload",
          "better-sqlite3",
          "cloudinary-all-in-one"
        ],
        "cost_band": {
          "min_usd_month": 3000,
          "max_usd_month": 50000
        },
        "rationale": "Managed all-in-one video services become cost-prohibitive past 100K DAU. Self-managed transcode farm + multi-region object store + read-replica DB required. Cloudinary/Mux full-stack disqualified at this tier (unit economics fail)."
      },
      "hyperscale": {
        "required_capabilities": [
          "blob_object_store",
          "transcode_worker",
          "cdn",
          "media_streaming_protocol",
          "relational_db_concurrent_writer",
          "cache_layer",
          "search_index",
          "image_thumbnail_pipeline",
          "fanout_queue",
          "notification_pipeline"
        ],
        "recommended_capabilities": [],
        "disqualified_packages": [
          "multer-disk",
          "express-fileupload",
          "better-sqlite3",
          "cloudinary-all-in-one",
          "mux-all-in-one"
        ],
        "cost_band": {
          "min_usd_month": 50000,
          "max_usd_month": 9999999
        },
        "rationale": "Multi-CDN, sharded write path, per-region edge cache, dedicated transcode farms. Custom storage tier (e.g. erasure-coded object store) likely displaces S3. Architecture must explicitly justify any managed dependency in capacity model."
      }
    }
  },
