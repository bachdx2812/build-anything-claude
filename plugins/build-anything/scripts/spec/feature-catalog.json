{
  "_stack_fitness_capabilities": {
    "_comment": "Reference dictionary read by stack-fitness-check.sh. Each capability defines: (a) what config keys satisfy it, (b) disqualified declarations that explicitly fail the gate, (c) example tech the skill accepts as evidence of fitness. The gate enforces presence — quality of choice is reviewer-judged.",
    "blob_object_store": {
      "satisfies_keys": [
        "backend.object_store.kind",
        "backend.blob_store.kind",
        "stack.object_store",
        "stack.media_storage",
        "stack.blob_store"
      ],
      "accept_values": [
        "s3",
        "minio",
        "gcs",
        "azure-blob",
        "r2",
        "b2",
        "cloudinary",
        "mux",
        "cloudflare-stream"
      ],
      "disqualified_values": [
        "local",
        "local-fs",
        "local-disk",
        "filesystem",
        "disk",
        "node-fs",
        "multer-disk",
        "tmpfs",
        "/tmp",
        ""
      ],
      "disqualified_packages": [
        "multer-disk",
        "express-fileupload",
        "multer"
      ],
      "rationale": "Large binary delivery from app-server disk does not survive horizontal scale, cannot CDN-cache reliably, and exhausts inodes."
    },
    "transcode_worker": {
      "satisfies_keys": [
        "backend.workers.transcode",
        "backend.queue.kind",
        "stack.transcode",
        "stack.queue"
      ],
      "accept_values": [
        "bullmq",
        "bullmq+ffmpeg",
        "sidekiq",
        "celery",
        "rq",
        "sqs",
        "rabbitmq",
        "kafka",
        "temporal",
        "mux",
        "aws-elastic-transcoder",
        "cloudflare-stream",
        "ffmpeg-worker"
      ],
      "disqualified_values": [
        "",
        "inline",
        "sync",
        "in-request"
      ],
      "rationale": "FFmpeg in the request path blocks the event loop / GIL and ties video duration to HTTP timeout. Belongs in a worker queue."
    },
    "cdn": {
      "satisfies_keys": [
        "cloud.cdn",
        "backend.cdn",
        "delivery.cdn",
        "stack.cdn"
      ],
      "accept_values": [
        "cloudflare",
        "cloudfront",
        "fastly",
        "bunny",
        "akamai",
        "gcp-cdn",
        "azure-front-door"
      ],
      "disqualified_values": [
        "",
        "origin-only",
        "none"
      ],
      "rationale": "Origin-only delivery at scale exhausts egress + latency targets."
    },
    "media_streaming_protocol": {
      "satisfies_keys": [
        "backend.streaming.protocol",
        "delivery.protocol",
        "stack.streaming_protocol",
        "stack.streaming"
      ],
      "accept_values": [
        "hls",
        "dash",
        "cmaf",
        "hls+dash"
      ],
      "disqualified_values": [
        "",
        "mp4-direct",
        "raw"
      ],
      "rationale": "Streaming raw MP4 forecloses adaptive bitrate, captions, and signed URLs."
    },
    "relational_db_concurrent_writer": {
      "satisfies_keys": [
        "backend.db.kind",
        "stack.db",
        "stack.database"
      ],
      "accept_values": [
        "postgres",
        "postgresql",
        "mysql",
        "mariadb",
        "cockroachdb",
        "spanner",
        "aurora",
        "planetscale"
      ],
      "disqualified_values": [
        "sqlite",
        "sqlite3",
        "better-sqlite3",
        "in-memory",
        "json-file"
      ],
      "disqualified_packages": [
        "better-sqlite3",
        "sql.js",
        "lowdb",
        "node-json-db"
      ],
      "rationale": "SQLite file-locks single writer; concurrent uploads / orders / messages cause writer contention or corruption."
    },
    "payment_processor": {
      "satisfies_keys": [
        "backend.payment.provider",
        "payment.provider",
        "stack.payment"
      ],
      "accept_values": [
        "stripe",
        "adyen",
        "braintree",
        "paypal",
        "checkout-com",
        "square",
        "razorpay",
        "midtrans",
        "vnpay",
        "sepay"
      ],
      "disqualified_values": [
        "",
        "none",
        "inline-card-table"
      ],
      "disqualified_schema_columns": [
        "card_number",
        "credit_card_number",
        "card_pan",
        "cc_number",
        "cvv",
        "cvc"
      ],
      "rationale": "Storing PANs/CVVs is PCI-DSS forbidden. Use a tokenizing provider."
    },
    "idempotency_store": {
      "satisfies_keys": [
        "backend.idempotency.endpoints",
        "backend.idempotency.store",
        "stack.idempotency"
      ],
      "accept_values_for_store": [
        "redis",
        "postgres",
        "dynamodb"
      ],
      "rationale": "Money-moving endpoints replayed without idempotency duplicate charges."
    },
    "geo_index": {
      "satisfies_keys": [
        "backend.geo.kind",
        "geo.index",
        "stack.geo"
      ],
      "accept_values": [
        "postgis",
        "redis-geo",
        "elasticsearch-geo",
        "algolia-places",
        "mongodb-geo",
        "h3"
      ],
      "disqualified_values": [
        "",
        "none",
        "table-scan"
      ],
      "rationale": "Geo `LIKE` / table-scan kills ride-hailing match latency budgets."
    },
    "realtime_transport": {
      "satisfies_keys": [
        "backend.realtime.kind",
        "realtime.transport",
        "stack.realtime"
      ],
      "accept_values": [
        "websocket",
        "socket.io",
        "phoenix-channels",
        "ws",
        "sse",
        "centrifugo",
        "ably",
        "pusher",
        "supabase-realtime",
        "firebase-rtdb"
      ],
      "disqualified_values": [
        "",
        "polling",
        "none"
      ],
      "rationale": "Chat over HTTP polling burns request budget and breaks presence semantics."
    },
    "fanout_queue": {
      "satisfies_keys": [
        "backend.fanout.kind",
        "backend.workers.fanout",
        "stack.fanout"
      ],
      "accept_values": [
        "redis-stream",
        "kafka",
        "rabbitmq",
        "sqs",
        "sidekiq",
        "bullmq"
      ],
      "disqualified_values": [
        "",
        "sync",
        "none"
      ],
      "rationale": "Synchronous follower fanout on tweet/post creation does not scale past ~10k followers."
    },
    "search_index": {
      "satisfies_keys": [
        "backend.search.kind",
        "search.engine",
        "stack.search"
      ],
      "accept_values": [
        "elasticsearch",
        "opensearch",
        "meilisearch",
        "typesense",
        "algolia",
        "pg-fts",
        "mysql-fts",
        "sonic"
      ],
      "disqualified_values": [
        "",
        "none",
        "like-query"
      ],
      "rationale": "LIKE %term% does not return relevance-ranked results and locks indices."
    },
    "cache_layer": {
      "satisfies_keys": [
        "backend.cache.kind",
        "stack.cache"
      ],
      "accept_values": [
        "redis",
        "memcached",
        "dragonfly",
        "keydb",
        "hazelcast"
      ],
      "rationale": "Hot-path read cache is required to hit p95 targets at meaningful RPS."
    },
    "notification_pipeline": {
      "satisfies_keys": [
        "backend.notifications.kind",
        "stack.notifications"
      ],
      "accept_values": [
        "fcm",
        "apns",
        "onesignal",
        "expo",
        "twilio",
        "sendgrid",
        "ses",
        "mailgun",
        "novu"
      ],
      "rationale": "Best-effort SMTP in-request blocks the dispatch path and loses messages on retry."
    },
    "image_thumbnail_pipeline": {
      "satisfies_keys": [
        "backend.workers.image",
        "backend.image_pipeline",
        "stack.image_pipeline"
      ],
      "accept_values": [
        "sharp+queue",
        "imgproxy",
        "thumbor",
        "cloudinary",
        "mux-image",
        "imagekit"
      ],
      "disqualified_values": [
        "",
        "inline-resize",
        "sync"
      ],
      "rationale": "Resizing uploads in-request burns CPU and ties response time to image dimensions."
    }
  },
  "_scale_tiers_meta": {
    "_comment": "v8.5 scale-tier dimension. Each product_type declares per-tier capability + cost + team requirements. Tier is selected from intent.declared.scale_tier; gate-stack matches the chosen tier row. Tiers escalate monotonically — growth must include mvp requirements, scale must include growth, etc. Verified by stack-fitness-check.sh (v8.5).",
    "tiers": {
      "mvp": {
        "dau_max": 1000,
        "rationale": "Single-region, single-AZ; managed all-in-one services acceptable; cost-optimised over performance; team 1-3."
      },
      "growth": {
        "dau_max": 100000,
        "rationale": "Multi-AZ within one region; dedicated caches/queues; CDN required; observability mandatory; team 2-10."
      },
      "scale": {
        "dau_max": 10000000,
        "rationale": "Multi-region read path; sharded or replicated writes; dedicated platform team; all-in-one managed services typically priced out; team 10-50."
      },
      "hyperscale": {
        "dau_max": null,
        "rationale": "Global edge + sharded write fabric + custom infrastructure layers. Likely warrants in-house storage/compute primitives; team 50+."
      }
    },
    "boring_tech_rule": "When a tier's required_capabilities are satisfied by multiple stacks, prefer the boring option (postgres > newsql, redis > exotic-cache, S3 > novel-object-store). Non-boring choices must justify with a capacity-model row in production-design.md."
  },
  "youtube-clone": {
    "keywords": [
      "youtube clone",
      "video sharing",
      "video platform",
      "vimeo clone",
      "video hosting",
      "youtube-clone"
    ],
    "must_have": [
      {
        "name": "video upload",
        "synonyms": [
          "upload video",
